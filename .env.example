# 🏙️ Dhaka Crime Index — Environment Variables
# Copy this to .env and fill in your real keys

# Groq API Key (Llama 3.3 70B)
GROQ_API_KEY=gsk_your_key_here

# AWS / LocalStack Credentials
# For local dev with LocalStack, use 'test' for keys
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# SQS Queue URL
# LocalStack: http://localstack:4566/000000000000/dhaka-crime-crawl-queue
SQS_CRAWL_QUEUE_URL=http://localstack:4566/000000000000/dhaka-crime-crawl-queue

# Database (PostGIS)
# docker-compose user/pass is crime/crime
DATABASE_URL=postgresql+asyncpg://crime:crime@db:5432/crimedb

# Redis (Upstash or Local)
UPSTASH_REDIS_URL=redis://redis:6379

# Storage Mode: "local" or "s3"
STORAGE_MODE=local
